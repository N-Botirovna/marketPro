# Frontend build-time env for the dev server.
# Copy to `.env` (which docker compose reads for build args):
#   cp .env.production.example .env
#
# NOTE: NEXT_PUBLIC_* is baked into the bundle at build time. After changing
# any value here you must rebuild: `docker compose up -d --build`.

# Backend REST API (trailing slash required).
NEXT_PUBLIC_API_BASE_URL=https://api-dev.kitobzor.uz/

# Support phone shown in footer / contact.
NEXT_PUBLIC_SUPPORT_PHONE=+998958430820

# Telegram bot for OTP / auto-login. Must match the bot configured on the
# backend (dev) — otherwise the login code is sent by a different bot.
NEXT_PUBLIC_BOT_USERNAME=kitobzorim_bot

# Optional Sentry DSN (leave empty to disable).
NEXT_PUBLIC_SENTRY_DSN=
