# Kitobzor frontend — copy to `.env.local` and fill in real values.
# `getApiBaseUrl()` (src/config/env.js) throws in production if NEXT_PUBLIC_API_BASE_URL is empty.

# Required in production. Local dev falls back to http://localhost:8000/ when unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/

# Customer-support phone shown in header / footer / contact.
NEXT_PUBLIC_SUPPORT_PHONE=+998 93 834 01 03

# Telegram bot username (no @, no t.me prefix). Used by the login page
# to render a "go to bot" link and by the AuthRequiredModal deep-link.
# Per env (.env.local / .env.production) so dev points at a test bot.
# Default (when unset): kitobzoruz_bot.
NEXT_PUBLIC_BOT_USERNAME=kitobzoruz_bot

# Idempotency-Key header — only enable once the backend lists
# `Idempotency-Key` in CORS_ALLOW_HEADERS, otherwise the browser will reject
# preflights and every mutation will fail with a Network Error.
# Leave unset (default) until the backend deploys the dedup middleware.
NEXT_PUBLIC_ENABLE_IDEMPOTENCY=

# Sentry — leave empty to disable (sentry.js becomes a no-op).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Set in CI to the deployed git SHA.
NEXT_PUBLIC_SENTRY_RELEASE=

# Server-side Sentry config (falls back to NEXT_PUBLIC_* values when unset).
# These are not bundled into the client.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
